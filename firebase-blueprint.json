{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "birthday": { "type": "string", "format": "date" },
        "role": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    },
    "cells/{cellId}": {
      "schema": "Cell",
      "description": "Shared collection of cells"
    },
    "members/{memberId}": {
      "schema": "Member",
      "description": "Shared collection of members"
    },
    "meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Shared collection of meetings"
    },
    "pastorNetworks/{networkId}": {
      "schema": "PastorNetwork",
      "description": "Shared collection of pastor networks"
    },
    "disciplerNetworks/{networkId}": {
      "schema": "DisciplerNetwork",
      "description": "Shared collection of discipler networks"
    }
  }
}
