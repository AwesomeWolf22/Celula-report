rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'birthday', 'role', 'phoneNumber', 'photoURL', 'createdAt', 'updatedAt'])
        && data.keys().size() == 9
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.birthday is string // Format usually ISO date
        && data.role in ['Lider', 'Treinador', 'Discipulador', 'Membro']
        && data.phoneNumber is string && data.phoneNumber.size() <= 20
        && data.photoURL is string && data.photoURL.size() <= 1000000 // Data URL limit
        && (data.createdAt == request.time || data.createdAt == existing().createdAt)
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming());
        
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      allow delete: if false; // Protect accounts from accidental deletion via client
    }
    
    // Shared Data (Universal access for all signed-in users)
    
    match /cells/{cellId} {
      allow read, write: if isSignedIn();
    }

    match /pastorNetworks/{networkId} {
      allow read, write: if isSignedIn();
    }

    match /disciplerNetworks/{networkId} {
      allow read, write: if isSignedIn();
    }

    match /members/{memberId} {
      allow read, write: if isSignedIn();
    }
    
    match /meetings/{meetingId} {
      allow read, write: if isSignedIn();
    }
  }
}
